<div class="sidebar-wrapper d-flex">
    <!-- ========================================================= -->
    <!-- 1. STATIC ICON BAR (Compact Width: 52px)                  -->
    <!-- ========================================================= -->
    <nav id="sidebar-icons" class="sidebar-icons text-white d-flex flex-column align-items-center py-2">
        
        <!-- Brand Header (Clickable Icon -> Menuju Home) -->
        <a asp-controller="Home" asp-action="Index" class="mb-3 mt-1 brand-container text-center text-warning text-decoration-none" title="Beranda Utama (Home)">
            <i class="bi bi-shield-lock-fill fs-5"></i>
        </a>

        <!-- Menu Items -->
        <ul class="nav flex-column align-items-center w-100 flex-grow-1">
            
            <!-- Menu Dashboard -->
            <li class="nav-item mb-1">
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link text-white icon-btn" title="Dashboard">
                    <i class="bi bi-columns-gap fs-6"></i>
                </a>
            </li>            
            
            <li class="nav-item mb-1">
                <a asp-controller="JournalEntry" asp-action="Create" class="nav-link text-white icon-btn" title="Journal Entry">
                    <i class="bi bi-journal-plus fs-6"></i>
                </a>
            </li>
            
            <li class="nav-item mb-1">
                <a href="javascript:void(0)" id="btn-toggle-reports" class="nav-link text-white icon-btn" title="Reports">
                    <i class="bi bi-folder fs-6"></i>
                </a>
            </li>
            
            <li class="nav-item mb-1">
                <a asp-controller="ChartOfAccounts" asp-action="Index" class="nav-link text-white icon-btn" title="Chart of Accounts">
                    <i class="bi bi-diagram-3 fs-6"></i>
                </a>
            </li>
        </ul>

        <!-- Bottom User Section -->
        <div class="mt-auto dropup">
            <a href="#" class="nav-link text-white icon-btn" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false" title="@(User.Identity?.Name ?? "User")">
                <i class="bi bi-person-circle fs-5"></i>
            </a>

            <!-- Popover Dropdown -->
            <ul class="dropdown-menu dropdown-menu-dark shadow ms-2 mb-2 fs-7" aria-labelledby="userDropdown">
                <li class="dropdown-header">@(User.Identity?.Name ?? "User")</li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item d-flex align-items-center" asp-controller="Settings" asp-action="Index">
                        <i class="bi bi-gear me-2"></i> Settings
                    </a>
                </li>
                <li>
                    <a class="dropdown-item d-flex align-items-center text-danger" asp-controller="Auth" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-2"></i> Sign Out
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- ========================================================= -->
    <!-- 2. EXPANDABLE FLYOUT PANEL (Reports Menu List - Compact)   -->
    <!-- ========================================================= -->
    <div id="reports-flyout" class="sidebar-flyout bg-dark border-end border-secondary text-white">
        <div class="p-2 border-bottom border-secondary d-flex justify-content-between align-items-center">
            <span class="fw-bold small text-uppercase tracking-wider text-warning mb-0">
                <i class="bi bi-folder2-open me-1"></i> Reports
            </span>
            <button type="button" id="btn-close-reports" class="btn-close btn-close-white btn-sm" aria-label="Close" style="font-size: 0.65rem;"></button>
        </div>

        <!-- List of Reports -->
        <div class="list-group list-group-flush p-1 small">
            <a asp-controller="GeneralJournal" asp-action="Index" class="list-group-item list-group-item-action bg-transparent text-white border-0 rounded my-1 py-1 px-2 d-flex align-items-center">
                <i class="bi bi-journal-bookmark me-2 text-warning"></i> General Journal
            </a>
            <a asp-controller="Reports" asp-action="GeneralLedger" class="list-group-item list-group-item-action bg-transparent text-white border-0 rounded my-1 py-1 px-2 d-flex align-items-center">
                <i class="bi bi-book me-2 text-info"></i> General Ledger
            </a>
            <a asp-controller="Reports" asp-action="TrialBalance" class="list-group-item list-group-item-action bg-transparent text-white border-0 rounded my-1 py-1 px-2 d-flex align-items-center">
                <i class="bi bi-calculator me-2 text-success"></i> General Ledger (Temporary Accounts)
            </a>
        </div>
    </div>
</div>