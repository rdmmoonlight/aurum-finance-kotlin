@{
    ViewData["Title"] = "Verifikasi Email";
    bool isSuccess = ViewBag.Success ?? false;
    string message = ViewBag.Message ?? "";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card p-4 shadow-lg text-center" style="width: 100%; max-width: 450px;">
        @if (isSuccess)
        {
            <div class="mb-3">
                <span style="font-size: 3.5rem;">✅</span>
            </div>
            <h3 class="fw-bold text-success mb-2">Email Terverifikasi!</h3>
            <p class="text-muted mb-4">@message</p>
            
            <a asp-controller="Home" asp-action="Index" class="btn btn-success w-100 py-2 font-weight-bold">
                Masuk ke Dashboard
            </a>
        }
        else
        {
            <div class="mb-3">
                <span style="font-size: 3.5rem;">❌</span>
            </div>
            <h3 class="fw-bold text-danger mb-2">Verifikasi Gagal</h3>
            <p class="text-muted mb-4">@message</p>

            <a asp-controller="Auth" asp-action="ResendVerification" class="btn btn-outline-primary w-100 mb-2">
                Kirim Ulang Email Verifikasi
            </a>
            <a asp-controller="Auth" asp-action="Login" class="btn btn-link text-decoration-none">
                Kembali ke Login
            </a>
        }
    </div>
</div>